# =============================================================================
# Build artifacts — rebuilt inside Docker; stale host copies must not leak in
# =============================================================================
dist/
.tmp-test/
coverage/
.nyc_output/

# =============================================================================
# Runtime dependencies — installed fresh inside Docker
# =============================================================================
node_modules/

# =============================================================================
# Credential and token files — NEVER bake into image layers
# =============================================================================
gcp-oauth.keys.json
tokens.json
client_secret.json
client_secret_*
*.key.json
service-account*.json
sa-*.json
.gcp-saved-tokens.json
google-tokens.json
accounts.json

# =============================================================================
# Test files — not needed for Docker build
# =============================================================================
test/
*.test.ts
*.spec.ts
tsconfig.test.json

# =============================================================================
# Development and editor files
# =============================================================================
.vscode/
.idea/
.cursor/
*.swp
*.swo
.editorconfig

# =============================================================================
# Documentation — not needed inside the image
# =============================================================================
README.md
CHANGELOG.md
DOCKER_USAGE.md
LICENSE
*.md

# =============================================================================
# Git internals
# =============================================================================
.git/
.gitignore
.gitattributes

# =============================================================================
# npm / package manager artifacts
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npmrc
.yarnrc
.pnpmfile.cjs

# =============================================================================
# Environment files
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# OS artifacts
# =============================================================================
.DS_Store
Thumbs.db
*.log
auth.log

# =============================================================================
# CI/CD configs
# =============================================================================
.github/
.gitlab-ci.yml
Jenkinsfile
.circleci/

# =============================================================================
# Lint config — only needed for local development
# =============================================================================
eslint.config.js
.eslintrc*
.eslintignore

# =============================================================================
# Host-side wrapper scripts — not needed inside the container
# =============================================================================
scripts/docker-mcp.sh

# =============================================================================
# Misc
# =============================================================================
.npmignore
.cursorignore
*.tmp
*.temp
.cache/
